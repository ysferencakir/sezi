# Database (Neon or local PostgreSQL)
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sezi

# Google OAuth2 (console.cloud.google.com → Fitness API etkinleştir)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# Spotify OAuth2 (developer.spotify.com/dashboard → app oluştur, Redirect URI'yi ekle)
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8000/auth/spotify/callback

# Notion (notion.so/my-integrations → internal integration oluştur, token'ı kopyala)
NOTION_TOKEN=
NOTION_DATABASE_ID=

# ScraperAPI (scraperapi.com) — eshot.gov.tr'nin Render/bulut IP'lerini engellemesi
# nedeniyle otobüs scraper'ı bunun üzerinden Türkiye IP'siyle geçiyor. Local'de
# genelde gerekmez (ev/ofis IP'leri engellenmiyor), Render'da (prod) gerekli.
SCRAPERAPI_KEY=

# Health Connect köprüsü — POST /api/health/ingest için paylaşımlı sır.
# Boş bırakılırsa endpoint kapalıdır. Uzun rastgele bir değer üret (ör. openssl rand -hex 32).
HEALTH_INGEST_TOKEN=

# altinapi.com (altinapi.com/docs → dashboard'dan key al) — gram + sarrafiye altın fiyatları
ALTINAPI_KEY=

# Yahoo Finance — auth gerekmez. BIST sembolleri ".IS" suffix'iyle, virgülle ayrılmış.
STOCKS_WATCHLIST=XU100.IS,ISCTR.IS

# TEFAS — auth gerekmez. Fon kodları, virgülle ayrılmış (ör. AFT,YAC).
TEFAS_WATCHLIST=

# Kobaküs Open Banking (kobakus.com/gelistiriciler → ekiple temas kur, firmCode/password/channelCode al)
KOBAKUS_FIRM_CODE=
KOBAKUS_PASSWORD=
KOBAKUS_CHANNEL_CODE=

# Strava OAuth2 (developer.strava.com → uygulama oluştur; Strava aboneliği gerekir)
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REDIRECT_URI=http://localhost:8000/auth/strava/callback

# TCMB EVDS (evds2.tcmb.gov.tr → ücretsiz kayıt, profil sayfasından API key al)
EVDS_API_KEY=

# camgoz.net Barkod API (jojapi.com/api/product-barcode-api → key al, bireysel ücretsiz).
# Key alındıktan sonra JoJ dashboard'da atanan gerçek gateway adresini CAMGOZ_API_BASE'e yaz
# (camgoz.net'e doğrudan istek 400 ile reddediliyor — sadece JoJ gateway üzerinden çalışıyor).
CAMGOZ_API_BASE=https://camgoz.net
CAMGOZ_API_KEY=

# EPİAŞ Şeffaflık Platformu (seffaflik.epias.com.tr → hesap oluştur) — TGT auth için
# kullanıcı adı/şifre. Kesinti sorgusu il koduna göre filtrelenir (boş = tüm TR).
EPIAS_USERNAME=
EPIAS_PASSWORD=
EPIAS_CITY_ID=

# Etkinlik.io RSS — auth gerekmez. Başlık/açıklamada aranacak şehir anahtar kelimesi.
ETKINLIK_CITY=İzmir

# Notifications (ntfy.sh - optional)
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=
NTFY_TOKEN=

# Notifications (Telegram - optional, @BotFather ile bot oluştur)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# App Configuration
APP_ENV=development
LOG_LEVEL=INFO
