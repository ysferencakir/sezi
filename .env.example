# Database
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/sezi

# Notifications (ntfy.sh)
NTFY_URL=https://ntfy.sh
NTFY_TOPIC=sezi-alerts
NTFY_TOKEN=          # isteğe bağlı, private topic için

# Google OAuth2 (console.cloud.google.com → Fitness API etkinleştir)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/auth/google/callback

# App
APP_ENV=development
LOG_LEVEL=INFO
